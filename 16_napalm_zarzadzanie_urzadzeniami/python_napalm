import json
from napalm import get_network_driver
driver = get_network_driver('ios')
iosvl2 = driver('192.168.122.250', 'cisco', 'cisco')
iosvl2.open()

print ('Wysylam konfiguracje do 192.168.122.250')
iosvl2.load_merge_candidate(filename='acl.cfg')

porownanie = iosvl2.compare_config()
if len(porownanie) > 0:
    print(porownanie)
    iosvl2.commit_config()
else:
    print('Konfiguracja juz byla, i nie wymaga wdrozenia.')
    iosvl2.discard_config()

iosvl2.close()




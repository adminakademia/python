import json
from napalm import get_network_driver

listaurzadzen = ['192.168.122.250',
           '192.168.122.251'
           ]

for adres_ip in listaurzadzen:
    print ("Podlaczam sie do " + str(adres_ip))
    driver = get_network_driver('ios')
    iosv = driver(adres_ip, 'cisco', 'cisco')
    iosv.open()
    iosv.load_merge_candidate(filename='acl.cfg')
    diffs = iosv.compare_config()
    if len(diffs) > 0:
        print(diffs)
        iosv.commit_config()
    else:
        print('Konfiguracja juz byla, i nie wymaga wdrozenia.')
        iosv.discard_config()
    iosv.close()

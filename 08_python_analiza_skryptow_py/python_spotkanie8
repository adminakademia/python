from netmiko import ConnectHandler

r1 = {
    'device_type': 'cisco_ios',
    'ip': '192.168.122.254',
    'username': 'cisco',
    'password': 'cisco'
}

net_connect = ConnectHandler(**r1)
output = net_connect.send_command('show version')
output2 = (output.find("IOSv"))

if output2 > 0:
    iosv = True
else:
    iosv = False

if iosv:
    print("Tak to jest urzadzenie z oprogramowaniem IOSv")
else:
    print("Nie, to nie jest urzadzenie z oprogramowaniem IOSv")



